{
  "version": 6,
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",
      "environment": {
        "PATH": "/usr/local/bin:/usr/bin:/bin",
        "CONDA_PREFIX": "",
        "CMAKE_PREFIX_PATH": "",
        "PKG_CONFIG_PATH": ""
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "environment": {
        "PATH": "/usr/local/bin:/usr/bin:/bin",
        "CONDA_PREFIX": "",
        "CMAKE_PREFIX_PATH": "",
        "PKG_CONFIG_PATH": ""
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "asan",
      "displayName": "ASan UBSan Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/asan",
      "environment": {
        "PATH": "/usr/local/bin:/usr/bin:/bin",
        "CONDA_PREFIX": "",
        "CMAKE_PREFIX_PATH": "",
        "PKG_CONFIG_PATH": ""
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_COMPILER": "clang++",
        "CONTEST_ENABLE_SANITIZERS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "asan",
      "configurePreset": "asan"
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "asan",
      "configurePreset": "asan",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
